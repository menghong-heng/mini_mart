# Copy this file to .env and fill in your local PostgreSQL credentials.
# Default assumes a database named "sentineldb" on localhost.
#
# When using Docker Compose these values are set automatically via
# the `environment:` block — you do NOT need a .env file.

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sentineldb

# CORS origin for the React dev server (Vite default port)
FRONTEND_ORIGIN=http://localhost:5173
